{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "noImplicitAny": false
  },
  "include": ["src/**/*", "index.ts", "entry-bundled.ts"],
  "exclude": ["node_modules", "dist"]
}
